# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Project 1 API base URL — must be running locally
PIPELINE_API_BASE=http://localhost:8000

# Agent settings
AGENT_MAX_PUBMED_RETRIES=2
AGENT_MAX_FETCH_RETRIES=1
AGENT_MODEL=claude-sonnet-4-20250514
AGENT_MAX_TOKENS=4096

# Cost guardrail — warn after this many runs per session
MAX_RUNS_PER_SESSION=20
